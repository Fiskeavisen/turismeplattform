{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/markedsplass/layout,_N_T_/markedsplass/page,_N_T_/markedsplass"
  },
  "segmentPaths": [
    "/_tree",
