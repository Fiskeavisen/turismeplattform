2:T115b,{"@context":"https://schema.org","@graph":[{"@type":"LocalBusiness","@id":"https://frimedia.no/#business","name":"Nordskjær Feriesenter","description":"Moderne hytter, båt og naturopplevelser mellom hav og fjell.","url":"https://frimedia.no","telephone":"+47 70 00 00 00","email":"booking@nordskjaer-demo.no","address":{"@type":"PostalAddress","addressLocality":"Nordskjær, Vestlandskysten","addressCountry":"NO"}},{"@type":"TouristTrip","name":"Havfiske med båt","description":"En trygg, guidet tur med lokalkjent skipper og stopp ved skjulte perler.","image":"https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":1290,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Båttur til Måkøy fyr","description":"Passer for både nybegynnere og erfarne gjester som vil tett på naturen.","image":"https://images.unsplash.com/photo-1534447677768-be436bb09401?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":890,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Fjellturer fra Nordskjær","description":"En fleksibel tur som kan tilpasses vær, gruppe og ambisjonsnivå.","image":"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":690,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Dagstur til kystbyen","description":"Et sosialt kveldsarrangement for grupper, bedrifter og reisefølger.","image":"https://images.unsplash.com/photo-1527004013197-933c4bb611b3?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":1190,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"LodgingBusiness","name":"Hytte type 1 med båt","description":"Moderne hytte for familier og små grupper, med kort vei til brygge og turstier.","image":"https://images.unsp