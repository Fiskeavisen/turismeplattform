2:T115b,{"@context":"https://schema.org","@graph":[{"@type":"LocalBusiness","@id":"https://frimedia.no/#business","name":"Nordskjær Feriesenter","description":"Moderne hytter, båt og naturopplevelser mellom hav og fjell.","url":"https://frimedia.no","telephone":"+47 70 00 00 00","email":"booking@nordskjaer-demo.no","address":{"@type":"PostalAddress","addressLocality":"Nordskjær, Vestlandskysten","addressCountry":"NO"}},{"@type":"TouristTrip","name":"Havfiske med båt","description":"En trygg, guidet tur med lokalkjent skipper og stopp ved skjulte perler.","image":"https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":1290,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Båttur til Måkøy fyr","description":"Passer for både nybegynnere og erfarne gjester som vil tett på naturen.","image":"https://images.unsplash.com/photo-1534447677768-be436bb09401?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":890,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Fjellturer fra Nordskjær","description":"En fleksibel tur som kan tilpasses vær, gruppe og ambisjonsnivå.","image":"https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":690,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"TouristTrip","name":"Dagstur til kystbyen","description":"Et sosialt kveldsarrangement for grupper, bedrifter og reisefølger.","image":"https://images.unsplash.com/photo-1527004013197-933c4bb611b3?auto=format&fit=crop&w=1200&q=80","offers":{"@type":"Offer","price":1190,"priceCurrency":"NOK","availability":"https://schema.org/InStock"}},{"@type":"LodgingBusiness","name":"Hytte type 1 med båt","description":"Moderne hytte for familier og små grupper, med kort vei til brygge og turstier.","image":"https://images.unsplash.com/photo-1439066615861-d1af74d74000?auto=format&fit=crop&w=1200&q=80","amenityFeature":[{"@type":"LocationFeatureSpecification","name":"Båt kan legges til"},{"@type":"LocationFeatureSpecification","name":"Kjøkken"},{"@type":"LocationFeatureSpecification","name":"Wifi"},{"@type":"LocationFeatureSpecification","name":"Terrasse"}]},{"@type":"LodgingBusiness","name":"Hytte type 2 for familier","description":"Enkelt, hyggelig og praktisk for aktive gjester som vil bruke dagen ute.","image":"https://images.unsplash.com/photo-1449158743715-0a90ebb6d2d8?auto=format&fit=crop&w=1200&q=80","amenityFeature":[{"@type":"LocationFeatureSpecification","name":"Frokostvalg"},{"@type":"LocationFeatureSpecification","name":"Wifi"},{"@type":"LocationFeatureSpecification","name":"Felles tørkerom"}]},{"@type":"Article","headline":"48 timer ved kysten","description":"En komplett helgeguide med hav, fjell, mat og lokale opplevelser.","image":"https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1200&q=80","url":"https://frimedia.no/artikler/48-timer-ved-kysten"},{"@type":"Article","headline":"Når bør du reise?","description":"Hva som passer best for fiske, fjelltur, familietur og roligere dager.","image":"https://images.unsplash.com/photo-1455156218388-5e61b526818b?auto=format&fit=crop&w=1200&q=80","url":"https://frimedia.no/artikler/nar-bor-du-reise"},{"@type":"Article","headline":"Lokale tips før du booker","description":"Slik velger du riktig opplevelse, riktig dag og riktig utstyr.","image":"https://images.unsplash.com/photo-1483347756197-71ef80e95f73?auto=format&fit=crop&w=1200&q=80","url":"https://frimedia.no/artikler/lokale-tips-for-du-booker"},{"@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Er båt inkludert ved hytteopphold?","acceptedAnswer":{"@type":"Answer","text":"Ja, hytteopphold kan settes opp med egen liten motorbåt eller som tillegg, avhengig av kundens oppsett."}},{"@type":"Question","name":"Kan gjester betale med Vipps elle