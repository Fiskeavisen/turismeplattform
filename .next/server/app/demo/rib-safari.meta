{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/demo/layout,_N_T_/demo/[tema]/layout,_N_T_/demo/[tema]/page,_N_T_/demo/rib-safari"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/demo/$d$tema/__PAGE__",
    "/demo/$d$tema",
    "/demo",
    "/_index",
    "/_head"
  ]
}